# EmuDeck toolkit configuration — copy to .env and fill in your values:
#
#     cp .env.example .env      # then edit .env
#
# .env is gitignored, so your real paths/IP never get committed. It's sourced by
# sync.sh and zip-status.sh. Every script also accepts these as positional args
# or already-exported env vars, so .env is optional — it just saves you typing.

# Folder of per-game ".zip" sets, laid out as "<System Name>/<Game>.zip"
# (e.g. a Redump/No-Intro torrent download). Read by import-zips.sh / zip-status.sh.
TORRENTS="/path/to/zip-sets"

# Your master library: the Emulation/ dir the whole toolkit reads from and writes
# to. Put it on a roomy drive — an external/Windows mount under /mnt is fine.
EMU_LIB="/mnt/e/Emulation"

# Steam Deck IP on your LAN. On the deck (Konsole): ip route get 1 | awk '{print $7; exit}'
# The deck needs sshd enabled. Leave blank to skip pushing to the deck.
DECK_IP="192.168.x.x"

# The deck's Emulation/ path on the SD card. Find it ON THE DECK with:
#     ls -d /run/media/*/Emulation
# Newer SteamOS mounts at /run/media/<LABEL>/Emulation (older used /run/media/deck/<LABEL>/).
CARD="/run/media/<LABEL>/Emulation"

# Free SteamGridDB API key (steamgriddb.com -> sign in -> Preferences -> API).
# Used by set-steam-art.py for Hero/Logo art and any covers libretro lacks.
SGDB_KEY=""
